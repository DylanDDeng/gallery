# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Supabase Admin (server-side only)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Admin
ADMIN_EMAILS=your_admin_email@example.com
USER_API_KEYS_ENCRYPTION_KEY=your_random_long_secret

# Billing
PAYMENT_PROVIDER=stripe
NEXT_PUBLIC_BASE_URL=https://your-domain.com
NEXT_PUBLIC_BILLING_ENABLED=true
NEXT_PUBLIC_SELF_SERVICE_API_KEYS_ENABLED=false

# Stripe
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs mapped to credit bundles
STRIPE_PRICE_SMALL=price_...   # 100 credits
STRIPE_PRICE_MEDIUM=price_...  # 500 credits
STRIPE_PRICE_LARGE=price_...   # 1000 credits
STRIPE_PRICE_PRO=price_...     # 2500 credits

# Paddle
NEXT_PUBLIC_PADDLE_CLIENT_TOKEN=test_...
PADDLE_API_KEY=your_paddle_api_key
PADDLE_WEBHOOK_SECRET=your_paddle_webhook_secret

# Paddle Price IDs mapped to credit bundles
PADDLE_PRICE_SMALL=pri_...   # 100 credits
PADDLE_PRICE_MEDIUM=pri_...  # 500 credits
PADDLE_PRICE_LARGE=pri_...   # 1000 credits
PADDLE_PRICE_PRO=pri_...     # 2500 credits

# AI provider
DOUBAO_API_KEY=your_doubao_api_key
