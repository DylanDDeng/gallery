# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Supabase Admin (server-side only)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Admin
ADMIN_EMAILS=your_admin_email@example.com

# Paddle
NEXT_PUBLIC_BASE_URL=https://your-domain.com
NEXT_PUBLIC_PADDLE_CLIENT_TOKEN=test_...
PADDLE_API_KEY=your_paddle_api_key
PADDLE_WEBHOOK_SECRET=your_paddle_webhook_secret

# Paddle Price IDs mapped to credit bundles
PADDLE_PRICE_SMALL=pri_...   # 100 credits
PADDLE_PRICE_MEDIUM=pri_...  # 500 credits
PADDLE_PRICE_LARGE=pri_...   # 1000 credits
PADDLE_PRICE_PRO=pri_...     # 2500 credits

# Seedream API (pending user providing API details)
SEEDDREAM_API_KEY=your_seedream_api_key
SEEDDREAM_API_ENDPOINT=https://api.seedream.io/v1
SEEDDREAM_CALLBACK_URL=https://your-domain.com/api/seedream/callback
